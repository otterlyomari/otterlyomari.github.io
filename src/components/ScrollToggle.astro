<button id="scroll-toggle" class="scroll-toggle" aria-label="Scroll">
	<span id="scroll-icon" class="t-outline">↓</span>
</button>

<style>
.scroll-toggle {
	position: fixed;
	right: 16px;
	bottom: 16px;
	width: 48px;
	height: 48px;

	border-radius: 999px;
	border: 1px solid rgba(255,255,255,0.4);
	background: rgba(0,0,0,0.6);
	backdrop-filter: blur(16px);
	color: white;

	display: flex;
	align-items: center;
	justify-content: center;

	cursor: pointer;
	z-index: 9999;

	opacity: var(--opacity, 0.85);

	/* ONLY transform lives here */
	transform:
		scaleX(var(--sx, 1))
		scaleY(var(--sy, 1));

	transform-origin: center;

	will-change: transform, opacity;

	transition: opacity 200ms ease;
}

/* hover override (still respects squash) */
.scroll-toggle:hover {
	--opacity: 1;
}

.scroll-toggle span {
	font-size: 40px;
	line-height: 1;
	display: flex;
	align-items: center;
	justify-content: center;
	transform: translateY(-6px);
	pointer-events: none;
}
</style>

<script is:inline>
function initScrollToggle() {
	if (window.__scrollToggleInit) {
		return;
	}
	window.__scrollToggleInit = true;

	const btn = document.getElementById("scroll-toggle");
	const icon = document.getElementById("scroll-icon");
	if (!btn || !icon) return;

	const scrollEl = document.scrollingElement || document.documentElement;

	let mode = "down";
	let idleTimer = null;

	// store latest layout size (no forcing scroll)
	let latestMaxScroll = () =>
		scrollEl.scrollHeight - window.innerHeight;

	function updateMode() {
		const pos = scrollEl.scrollTop;
		const max = latestMaxScroll();

		if (pos <= 5) {
			mode = "down";
			icon.textContent = "↓";
		} else if (pos >= max - 5) {
			mode = "up";
			icon.textContent = "↑";
		} else {
			mode = pos < max / 2 ? "down" : "up";
			icon.textContent = mode === "up" ? "↑" : "↓";
		}
	}

	// ---------- SAFE SCROLL ----------
	function scrollToTarget() {
		// always compute at click time (critical fix)
		const max = latestMaxScroll();
		const pos = scrollEl.scrollTop;

		const target = pos <= 5 ? max : 0;

		scrollEl.scrollTo({
			top: target,
			behavior: "smooth"
		});
	}

	// ---------- RESIZE OBSERVER (NO SCROLLING HERE) ----------
	const ro = new ResizeObserver(() => {
		// only update internal state, NEVER scroll
		// (this removes flicker completely)
		updateMode();
	});

	ro.observe(document.documentElement);

	// ---------- EVENTS ----------
	btn.addEventListener("click", () => {
		updateMode();
		scrollToTarget();
	});

	window.addEventListener("scroll", () => {
		updateMode();

		clearTimeout(idleTimer);
		idleTimer = setTimeout(updateMode, 120);
	}, { passive: true });

	window.addEventListener("resize", updateMode);
	window.addEventListener("load", updateMode);

	requestAnimationFrame(updateMode);
}

initScrollToggle();
</script>