---
const { entry } = Astro.props;
---

<a
  href={`/library/${entry.id}`}
  class="archive-card"
  data-tags={entry.data.tags.join(",")}
  data-id={entry.id}
  data-type={entry.data.type}
  data-astro-prefetch
>
  {entry.data.cover && (
    <img
      class="archive-card-cover"
      src={entry.data.cover}
      alt={entry.data.title}
    />
  )}

  <div class="archive-card-content">
    <h3 class="archive-card-title">{entry.data.title}</h3>

    <p class="archive-card-meta">
      <span>{entry.data.type}</span>
      <span>{entry.data.pubDate.toDateString()}</span>
    </p>

    <!-- Resume badge (populated client-side) -->
    <div class="archive-resume" data-resume-id={entry.id}>
      <!-- filled by JS if reading state exists -->
    </div>
  </div>
</a>