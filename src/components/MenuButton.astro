---
const {
	href,
	label,
	class: className = ""
} = Astro.props;
---

<a href={href} class={`menu-button no-deco ${className}`}>
	<span class="menu-button__text t-outline">
		{label}
	</span>
</a>

<style>
.menu-button {
	width: 100%;
	height: auto;

	display: inline-flex;
	align-items: center;
	justify-content: center;

	padding: 0.75rem 1rem;
	margin: 0.8rem 0;

	border-radius: 5%;
	border: none;              
	background: white;  

	font-size: 2em;       

	color: inherit;
	text-decoration: none;

	cursor: pointer;

	-webkit-animation: scale-up 0.6s;
	-webkit-animation-fill-mode: forwards;

	animation: revert-scale 0.3s;
	animation-fill-mode: forwards;

	filter:
		drop-shadow(-1px -1px 0px #000000)
		drop-shadow(2px -1px 0px #000000)
		drop-shadow(2px 2px 0px #000000)
		drop-shadow(-1px 2px 0px #000000);

	appearance: none;
	-webkit-appearance: none;
}

.menu-button__text {
    color: #ffffff
}

.menu-button__text:hover {
    color: #000000
}

.menu-button:hover {
	animation: scale-up 0.5s;
	animation-fill-mode: forwards;

	background-color: red;
	border-color: rgb(175, 0, 0);
}

.menu-button:hover .t-outline {
	filter:
		drop-shadow(-1px -1px 0px #ffffff)
		drop-shadow(2px -1px 0px #ffffff)
		drop-shadow(2px 2px 0px #ffffff)
		drop-shadow(-1px 2px 0px #ffffff);
}
</style>