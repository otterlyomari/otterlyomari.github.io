---
import BaseHead from '../components/BaseHead.astro';
import ScrollToggle from '../components/ScrollToggle.astro';
import { SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title={"OtterlyOmari | Gallery"} description={SITE_DESCRIPTION} />
</head>

<body>

<script type="module" src="/scripts/gallery-core.js?reload"></script>
<script type="module" src="/scripts/gallery-lightbox.js?reload"></script> <!-- REQUIRED FOR ADDITIONAL LIGHTBOX FUNCTIONALITY -->
<script type="module" src="/scripts/hackermantm.js?v=1"></script>

<main id="content">

<div id="home-section">

	<a href="/">
		<img src="/logo.png" class="image" />
	</a>

	<h5 class="t-outline" style="text-align:center;">
		the cute motherfluffer your mom warned you about
	</h5>

	<br>
	<h4 class="t-outline filters-title">Filters</h4>

	<div class="gallery-controls">
		<button class="filter-btn active" data-filter="all">All</button>
		<button class="filter-btn" data-filter="art">🎨 Artwork</button>
		<button class="filter-btn" data-filter="vrchat">📸 VRChat</button>
	</div>

	<!-- MASONRY ROOT -->
	<div id="gallery"></div>

	<br />

	<button>
		<a href="/" class="no-deco">
			<h4 class="t-outline t-has-hover">Go Back</h4>
		</a>
	</button>

</div>

</main>

<ScrollToggle />



<style>
main {
	backdrop-filter: blur(0.4rem);
	background: transparent;
}

#home-section {
	max-width: none;
	width: 100%;
	margin: 0;
}

.t-has-hover {
	transition: color 0.1s ease;
	text-align: center;
}

.t-has-hover:hover {
	color: black;
}

.gallery-controls {
	display: flex;
	justify-content: center;
	gap: 10px;
	flex-wrap: wrap;
	margin: 1.5rem 0;
}

.filters-title {
	margin: 1rem 0 0.5rem;
	text-align: center;
	opacity: 0.85;
	letter-spacing: 1px;
}

.filter-btn {
	padding: 6px 12px;
	font-size: 1.5rem;
	font-family: 'Pulang', sans-serif;
	border: 1px solid #fff;
	background: rgba(0,0,0,0.35);
	color: white;
	border-radius: 6px;
	cursor: pointer;
}

.filter-btn.active {
	background: white;
	color: black;
}

#gallery {
  position: relative;

  /* FULL BLEED HACK */
  width: 100vw;
  max-width: 100vw;

  /* break out of centered container */
  margin-left: calc(50% - 50vw);
  margin-right: calc(50% - 50vw);

  overflow: visible;
}
.gallery-item-wrapper {
  position: absolute;
}

.gallery-item-wrapper img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 10px;
}

.gallery-item-wrapper img.loaded {
  opacity: 1;
}

@media (max-width: 700px) {
	#gallery {
		width: 100vw;
		left: auto;
		transform: none;
	}
}

@media (max-width: 480px) {

	.gallery-controls {
		flex-direction: column;
		align-items: center;
	}

	.filter-btn {
		width: 100%;
		max-width: 220px;
	}

}


.gallery-item-wrapper img.loaded {
  opacity: 1;
}

@media (max-width: 480px) {
	.filter-btn {
		width: 100%;
		max-width: 220px;
	}

	.gallery-controls {
		flex-direction: column;
		align-items: center;
	}
}

h1,
h2,
h3,
h4,
h5,
h6 {
	margin: 0 0 0.5rem 0;
	color: white;
	line-height: 1.2;
	font-family: 'Pulang', sans-serif;
}

#lightbox {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.75);
  backdrop-filter: blur(10px);
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
  z-index: 9999;
}

#lightbox.hidden {
  display: none;
}

#lightbox-img {
  position: absolute;

  width: 45%;
  height: auto;

  transform-origin: center center;
  will-change: transform;

  /* hide no-drop/forbidden cursor */
 -webkit-user-drag: none;
  user-select: none;
  -webkit-touch-callout: none;
  pointer-events: auto;
}

#lightbox-img:active {
  cursor: grabbing;
}

html, body {
  overscroll-behavior: none;
}
</style>

<div id="lightbox" class="lightbox hidden">
  <img id="lightbox-img" />
</div>

</body>
</html>