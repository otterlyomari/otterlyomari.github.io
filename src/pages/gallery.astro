---
import BaseHead from '../components/BaseHead.astro';
import ScrollToggle from '../components/ScrollToggle.astro';
import { SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title={"OtterlyOmari | Gallery"} description={SITE_DESCRIPTION} />
</head>

<body>

<script type="module" src="/scripts/gallery-core.js?reload"></script>
<script type="module" src="/scripts/hackermantm.js?v=1"></script>

		

<main id="content">

<div id="home-section">

	<a href="/">
		<img src="/logo.png" class="image" />
	</a>

	<h5 class="t-outline" style="text-align:center;">
		the cute motherfluffer your mom warned you about
	</h5>

	<br>
	<h4 class="t-outline filters-title">Filters</h4>

	<div class="gallery-controls">
		<button class="filter-btn active" data-filter="all">All</button>
		<button class="filter-btn" data-filter="art">🎨 Artwork</button>
		<button class="filter-btn" data-filter="vrchat">📸 VRChat</button>
	</div>

	<!-- MASONRY ROOT -->
	<div id="gallery"></div>

	<br />

	<button>
		<a href="/" class="no-deco">
			<h4 class="t-outline">Go Back</h4>
		</a>
	</button>

</div>

</main>

<ScrollToggle />



<style>
main {
	backdrop-filter: blur(0.4rem);
	background: transparent;
}

#home-section {
	max-width: 1200px;
	margin: 0 auto;
	text-align: center;
}

.gallery-controls {
	display: flex;
	justify-content: center;
	gap: 10px;
	flex-wrap: wrap;
	margin: 1.5rem 0;
}

.filters-title {
	margin: 1rem 0 0.5rem;
	text-align: center;
	opacity: 0.85;
	letter-spacing: 1px;
}

.filter-btn {
	padding: 6px 12px;
	border: 1px solid #fff;
	background: rgba(0,0,0,0.35);
	color: white;
	border-radius: 6px;
	cursor: pointer;
}

.filter-btn.active {
	background: white;
	color: black;
}

#gallery {
	column-count: 4;
	column-gap: 16px;
	column-fill: balance;

	width: 100vw;
	max-width: 100vw;
	position: relative;
	left: 50%;
	transform: translateX(-50%);
	padding: 12px;
	box-sizing: border-box;
}

@media (max-width: 1000px) {
	#gallery { column-count: 3; }
}

@media (max-width: 700px) {
	#gallery { column-count: 2; }
}

.gallery-item-wrapper {
	position: relative;
	z-index: 1;
}

.gallery-item-wrapper img {
	width: 100%;
	display: block;
	border-radius: 10px;
	cursor: pointer;

	aspect-ratio: 4 / 3;
	object-fit: cover;

	filter: blur(14px);
	transform: scale(1.02);
	opacity: 0;

	transition: all 300ms ease;
	will-change: transform, opacity, filter;
}

@media (max-width: 480px) {
	.filter-btn {
		width: 100%;
		max-width: 220px;
	}

	.gallery-controls {
		flex-direction: column;
		align-items: center;
	}
}
</style>


</body>
</html>