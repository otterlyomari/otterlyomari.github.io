---
import BaseHead from '../components/BaseHead.astro';
import { SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title={"OtterlyOmari | Gallery"} description={SITE_DESCRIPTION} />
</head>

<body>

<script type="module" src="/scripts/gallery-core.js?reload"></script>
<script type="module" src="/scripts/hackermantm.js?v=1"></script>

		

<main id="content">

<div id="home-section">

	<a href="/">
		<img src="/logo.png" class="image" />
	</a>

	<h5 class="t-outline" style="text-align:center;">
		the cute motherfluffer your mom warned you about
	</h5>

	<br>
	<h4 class="t-outline filters-title">Filters</h4>

	<div class="gallery-controls">
		<button class="filter-btn active" data-filter="all">All</button>
		<button class="filter-btn" data-filter="art">🎨 Artwork</button>
		<button class="filter-btn" data-filter="vrchat">📸 VRChat</button>
	</div>

	<!-- MASONRY ROOT -->
	<div id="gallery"></div>

	<br />

	<button>
		<a href="/" class="no-deco">
			<h4 class="t-outline">Go Back</h4>
		</a>
	</button>

</div>

</main>

<button id="scroll-toggle" aria-label="Scroll" class="scroll-toggle"><span class="t-outline">↓</span></button>

<style>
main {
	backdrop-filter: blur(0.4rem);
	background: transparent;
}

#home-section {
	max-width: 1200px;
	margin: 0 auto;
	text-align: center;
}

.gallery-controls {
	display: flex;
	justify-content: center;
	gap: 10px;
	flex-wrap: wrap;
	margin: 1.5rem 0;
}

.filters-title {
	margin: 1rem 0 0.5rem;
	text-align: center;
	opacity: 0.85;
	letter-spacing: 1px;
}

.filter-btn {
	padding: 6px 12px;
	border: 1px solid #fff;
	background: rgba(0,0,0,0.35);
	color: white;
	border-radius: 6px;
	cursor: pointer;
}

.filter-btn.active {
	background: white;
	color: black;
}

#gallery {
	column-count: 4;
	column-gap: 16px;
	column-fill: balance;

	width: 100vw;
	max-width: 100vw;
	position: relative;
	left: 50%;
	transform: translateX(-50%);
	padding: 12px;
	box-sizing: border-box;
}

@media (max-width: 1000px) {
	#gallery { column-count: 3; }
}

@media (max-width: 700px) {
	#gallery { column-count: 2; }
}

.gallery-item-wrapper {
	position: relative;
	z-index: 1;
}

.gallery-item-wrapper img {
	width: 100%;
	display: block;
	border-radius: 10px;
	cursor: pointer;

	aspect-ratio: 4 / 3;
	object-fit: cover;

	filter: blur(14px);
	transform: scale(1.02);
	opacity: 0;

	transition: all 300ms ease;
	will-change: transform, opacity, filter;
}

@media (max-width: 480px) {
	.filter-btn {
		width: 100%;
		max-width: 220px;
	}

	.gallery-controls {
		flex-direction: column;
		align-items: center;
	}
}

.scroll-toggle {
	position: fixed;
	right: 16px;
	bottom: 16px;
	width: 48px;
	height: 48px;

	border-radius: 999px;
	border: 1px solid rgba(255,255,255,0.4);
	background: rgba(0,0,0,0.6);
	backdrop-filter: blur(16px);
	color: white;

	display: flex;
	align-items: center;
	justify-content: center;

	padding: 0;
	cursor: pointer;
	z-index: 9999;

	opacity: 0.85;
	transition: transform 0.2s ease, opacity 0.2s ease;
}

.scroll-toggle span {
	font-size: 40px;
	line-height: 1;
	display: flex;
	align-items: center;
	justify-content: center;
	transform: translateY(-6px);
}

.scroll-toggle:hover {
	transform: scale(1.08);
	opacity: 1;
}

.scroll-toggle:active {
	transform: scale(0.95);
}
</style>

<script>
const btn = document.getElementById("scroll-toggle");
const icon = btn?.querySelector("span");

function getScrollPosition() {
	return window.scrollY || document.documentElement.scrollTop;
}

function getMaxScroll() {
	return document.documentElement.scrollHeight - window.innerHeight;
}

function isAtTop() {
	return getScrollPosition() <= 5;
}

function isAtBottom() {
	return getScrollPosition() >= getMaxScroll() - 5;
}

function updateButton() {
	if (!btn || !icon) return;

	// TOP → always show DOWN
	if (isAtTop()) {
		icon.textContent = "↓";
		btn.dataset.mode = "down";
		return;
	}

	// BOTTOM → show UP
	if (isAtBottom()) {
		icon.textContent = "↑";
		btn.dataset.mode = "up";
		return;
	}

	// MID SCROLL → decide based on which direction is closer
	const halfway = getMaxScroll() / 2;

	if (getScrollPosition() < halfway) {
		icon.textContent = "↓";
		btn.dataset.mode = "down";
	} else {
		icon.textContent = "↑";
		btn.dataset.mode = "up";
	}
}

function scrollToTop() {
	window.scrollTo({ top: 0, behavior: "smooth" });
}

function scrollToBottom() {
	window.scrollTo({ top: getMaxScroll(), behavior: "smooth" });
}

btn?.addEventListener("click", () => {
	if (btn.dataset.mode === "up") {
		scrollToTop();
	} else {
		scrollToBottom();
	}
});

// keep in sync
window.addEventListener("scroll", updateButton);
window.addEventListener("resize", updateButton);
document.addEventListener("DOMContentLoaded", updateButton);

// initial sync
updateButton();
</script>

</body>
</html>