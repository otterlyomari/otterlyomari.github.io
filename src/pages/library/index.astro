---
import BaseHead from '../../components/BaseHead.astro';
import SearchBar from '../../components/archive/SearchBar.astro';
import TypeFilter from '../../components/archive/TypeFilter.astro';
import { getCollection } from 'astro:content';
import { SITE_DESCRIPTION } from '../../consts';
import MenuButton from '../../components/MenuButton.astro';
import Footer from '../../components/Footer.astro';

const archive = await getCollection("library");

const allTypes = [...new Set(archive.map(entry => entry.data.type))];
---

<html lang="en">
  <head>
    <BaseHead title="OtterlyOmari | Library" description={SITE_DESCRIPTION} />

    <!-- Library dependencies -->
    <script src="https://cdn.jsdelivr.net/npm/fuse.js@6.6.2" defer></script>
    <script src="/scripts/archive-core.js" defer></script>
    
  </head>

  <body class="archive-mode">
    <main>
      <!-- HERO -->
      <section class="archive-hero">
        <h1 class="t-outline">The Library</h1>
        <br>
        <p class="t-outline"><i>A collection of all my work, from poems, to short stories, and more.</i></p>
      </section>

      <!-- CONTROLS -->
      <section class="archive-controls">
        <SearchBar />

        <!-- Filter by Entry Type -->
        <TypeFilter types={allTypes} />

        <!-- Sort Controls -->
        <div class="sort-controls">
          <select id="archiveSort" class="sort-select t-outline">
            <option value="default">Sort: Default</option>
            <option value="az">A → Z</option>
            <option value="za">Z → A</option>
          </select>
        </div>
      </section>

      <!-- GRID (JS owns this now) -->
      <section class="archive-grid" id="archiveGrid"></section>

      <!-- BACK -->
   		<MenuButton class="menu-button-lib" href="/" label="Go Back" />

    </main>
    <Footer class="t-outline"/>

    <!-- DATA INJECTION -->
    <script is:inline define:vars={{ archive }}>
      window.archiveData = archive.map(entry => ({
        id: entry.id,
        title: entry.data.title,
        description: entry.data.description,
        tags: entry.data.tags,
        type: entry.data.type,
        cover: entry.data.cover ?? null
      }));
    </script>
  <style>
    .menu-button-lib {
      font-family: "Source Serif 4", serif;
      transition: 0.2s ease;
    }

    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      margin: 0 0 0.5rem 0;
      color: white;
      line-height: 1.2;
      font-family: 'Source Serif 4', sans-serif;
    }

    .archive-mode {
      margin: 0;
      padding: 0;
      min-height: 100vh;
      color: #f2f2f2;
      font-family: "Georgia", serif;

      
      background-image: url('/library-bg.webp');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
        backdrop-filter: blur(5px);

      min-height: 100vh;
    }

    main  {
      background: rgba(10, 10, 10, 0.4);
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(6px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .archive-mode main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
    }

    .archive-hero {
      text-align: center;
      padding: 3rem 1rem 2rem;
    }

    .archive-hero h1 {
      font-size: 3rem;
      font-family: "Whisper", serif;
      margin: 0;
      letter-spacing: 0.5px;
    }

    .archive-hero p {
      opacity: 0.7;
      margin-top: 0.5rem;
    }

    /* Replace the existing .archive-controls and .archive-controls > * rules */
    .archive-controls {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      gap: 1rem;
      padding: 1rem 0 2rem;
      flex-wrap: wrap;
    }

    /* Search bar gets most of the space, filters wrap naturally */
    .archive-controls > *:first-child {
      flex: 1 1 300px;
      min-width: 0;
    }

    .archive-controls > *:not(:first-child) {
      flex: 0 1 auto;
    }

    .archive-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.2rem;
      padding-top: 1rem;
      margin-bottom: 2.5rem;
    }

    /* tablets */
    @media (max-width: 900px) {
      .archive-hero h1 {
        font-size: 2.5rem;
      }

      .archive-grid {
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      }
    }

    /* phones */
    @media (max-width: 600px) {

      .archive-mode main {
        padding: 1rem 0.85rem 3rem;
        width: 100%;
        max-width: 100%;
      }

      .archive-hero {
        padding: 1.5rem 0 1rem;
      }

      .archive-hero h1 {
        font-size: 2rem;
        line-height: 1;
      }

      .archive-hero p {
        font-size: 0.95rem;
        line-height: 1.4;
        padding: 0 0.5rem;
      }

      /* STACK SEARCH + FILTERS */
      .archive-controls {
        flex-direction: column;
        align-items: stretch;
        gap: 0.8rem;

        width: 100%;
        padding: 0.5rem 0 1.5rem;
      }

      .archive-controls > * {
        width: 100%;
        max-width: 100%;
      }

      /* FILTER BUTTON WRAP */
      .tag-filter {
        justify-content: center;
      }

      .tag-btn {
        flex: 1 1 auto;
        justify-content: center;
        min-height: 42px;
      }

      /* SINGLE COLUMN GRID */
      .archive-grid {
        grid-template-columns: 1fr;
        gap: 1rem;
        padding-top: 0.5rem;
      }

      /* CARD TWEAKS */
      .archive-card {
        padding: 0.9rem;
        border-radius: 12px;
      }

      .archive-card h3 {
        font-size: 1rem;
      }

      .archive-card p {
        font-size: 0.85rem;
        line-height: 1.4;
      }

      .archive-cover {
        height: 180px;
      }

      /* BACK BUTTON */
      button {
        width: 100%;
      }

      button > a > h4 {
        font-size: 1.2rem;
      }
      
    }

    .sort-select {
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: white;
    padding: 6px 12px;
    border-radius: 6px;
    font-family: 'Source Serif 4', serif;
    font-size: 0.9rem;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
  }

  .sort-select option {
    background: #1a1a1a;
    color: white;
  }

  .sort-select:focus {
    outline: none;
    border-color: rgba(255, 255, 255, 0.6);
  }



  </style>
  </body>
</html>