---
import { getCollection, render } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import MenuButton from "../../components/MenuButton.astro";
import Footer from "../../components/Footer.astro";
import ScrollToggle from "../../components/ScrollToggle.astro";

export async function getStaticPaths() {
  const library = await getCollection("library");

  return library.map((entry) => ({
    params: { slug: entry.id },
  }));
}

const { slug } = Astro.params;

const library = await getCollection("library");
const entry = library.find((e) => e.id === slug);

if (!entry) {
  return Astro.redirect("/404");
}

const { Content } = await render(entry);

const pubDate = entry.data.pubDate
  ? new Date(entry.data.pubDate)
  : null;

const isNovelSample = entry.data.type === "Novel Sample";
---

<html lang="en">
  <head>
    <BaseHead title={entry.data.title ?? "Library"} description={entry.data.description ?? ""} type="article" pubDate={pubDate ?? undefined}  tags={entry.data.tags}/>
    <link rel="preload" href="/fonts/Whisper-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/SourceSerif4Roman-Regular.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="entry-page">
    <main class="entry-container">

        {!isNovelSample && (
          <>
            <h1 class="entry-title t-outline">
              {entry.data.title}
            </h1>

            <p class="entry-description t-outline">
              <i>{entry.data.description}</i>
            </p>

            <div class="entry-meta">
              <span class="entry-type t-outline">{entry.data.type}</span>
              <span class="entry-date t-outline">
                {entry.data.pubDate.toDateString()}
              </span>
            </div>
          </>
        )}

          {entry.data.cover && (
            <img
              src={entry.data.cover}
              alt={entry.data.title}
              class="entry-cover"
            />
          )}
        </header>

          <article class="entry-content t-outline">
            <Content />
          </article>

          <MenuButton class="menu-button-lib" href="/library" label="Go Back" />

      </main>
           
      <Footer class="t-outline" />
      <ScrollToggle />

      <style>
        
        :global(:is(h1, h2, h3, h4, h5, h6):not(.entry-title)) {
          margin: 0 0 0.5rem 0;
          color: white;
          line-height: 1.2;
          font-family: 'Source Serif 4', sans-serif !important;
          font-style: italic;
          font-weight: 500;
        }

       .menu-button-lib {
          font-family: "Source Serif 4", serif;
          transition: 0.2s ease;
        }

        @media (max-width: 600px) {
          .menu-button-lib {
            width: 100%;
          }
        }

        .entry-page::before {
          content: "";
          position: fixed;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
          backdrop-filter: blur(5px);
          z-index: -1;
        }

        .entry-page {
          color: #f2f2f2;
          font-family: "Georgia", serif;
          line-height: 1.6;
          margin: 0;
          padding: 0;
          background-image: url('/library-bg.webp');
          background-size: cover;
          background-position: center;
          background-repeat: no-repeat;

          min-height: 100vh;
        }

        .entry-container {
          background-color: rgba(20, 20, 20, 0.75);
          max-width: 800px;
          margin: 0 auto;
          padding: 3rem 1.5rem;
          width: min(800px, 100%);
          box-sizing: border-box;
        }

        .entry-header {
          margin-bottom: 2rem;
        }

        .entry-title {
          font-size: clamp(2rem, 4vw, 3.5rem);
          font-family: "Whisper", serif;
          text-align: center;
        }

        .entry-description {
          opacity: 0.75;
          text-align: center;
        }

        .entry-meta {
          display: flex;
          gap: 1rem;
          font-size: 0.75rem;
          opacity: 0.6;
          justify-content: center;
          flex-wrap: wrap;
        }

        .entry-cover {
          width: 100%;
          border-radius: 12px;
          margin-top: 1rem;
          border: 1px solid rgba(255,255,255,0.08);
          object-fit: cover;
        }

        .entry-content {
          line-height: 1.75;
          font-size: 1rem;
          font-family: "Source Serif 4", serif;
          margin-bottom: 2.5rem;
        }

        .entry-content p {
          margin: 1rem 0;
        }

        .entry-content img {
          max-width: 100%;
          border-radius: 10px;
        }

        .entry-content a {
          color: #cfd8ff;
          text-decoration: underline;
        }
      </style>

