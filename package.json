{
  "name": "otterlyomari",
  "type": "module",
  "version": "3.2.10",
  "standard-version": {
    "scripts": {
      "postbump": "echo version bumped"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix"
    ],
    "*.{astro}": [
      "eslint"
    ]
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "release": "standard-version",
    "release:patch": "standard-version --release-as patch",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^13.6.0",
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/react": "^5.0.6",
    "@astrojs/rss": "^4.0.18",
    "@iconify-json/bi": "^1.1.23",
    "@iconify-json/carbon": "^1.1.30",
    "@jop-software/astro-cookieconsent": "^3.0.0",
    "@types/react": "^18.2.58",
    "@types/react-dom": "^18.2.19",
    "astro": "^6.4.2",
    "astro-icon": "^1.1.5",
    "astro-navbar": "^2.3.1",
    "bootstrap-icons": "^1.11.3",
    "fuse.js": "^7.3.0",
    "gsap": "^3.12.5",
    "hamburgers": "^1.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "vanilla-cookieconsent": "^3.0.0",
    "vite-plugin-html": "^3.2.2",
    "wrangler": "^4.95.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@iconify-json/mdi": "^1.1.64",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "sass": "^1.71.1",
    "standard-version": "^9.5.0",
    "typescript-eslint": "^8.60.1",
    "vite": "^7.3.3"
  }
}
